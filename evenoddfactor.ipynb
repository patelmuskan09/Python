   ],
   "source": [
    "n= int(input(\"ENTER NUMBER:\"))\n",
    "i=1\n",
    "while i<=n:\n",
    " if n%i==0 and i%2==0:\n",
    "   print(i, \"is EVEN\")\n",
    " elif n%i==0 and i%2!=0:\n",
    "    print(i, \"is ODD\")\n",
    " i+=1\n"
   ]
  }
